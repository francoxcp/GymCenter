<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Configuration
  Bloquea tráfico HTTP (cleartext) para toda la app.
  Solo permite conexiones HTTPS con TLS 1.2+.
  Certificate Transparency habilitado para Supabase.
-->
<network-security-config>
    <!-- Configuración base: prohibir cleartext en toda la app -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
      Certificate pinning para el dominio de Supabase.
      Pins calculados: Sun, 25 Mar 2026
      - supabase.co leaf certificate (CN=supabase.co, WE1 intermediate)
      - WE1 intermediate (Google Trust Services)
      Si los pins fallan, la conexión será rechazada (MITM protection).
      Expiration: 25 de Marzo de 2028 (2 años).
      Para renovar, ejecutar: scripts/get_cert_pins.ps1
    -->
    <domain-config>
        <domain includeSubdomains="true">supabase.co</domain>
        <pin-set expiration="2028-03-25">
            <!-- Leaf certificate (supabase.co) -->
            <pin digest="SHA-256">M4FlSvpxk5vEw3n70qj3t4y7QuYUHuzwkh9Earv1FNQ=</pin>
            <!-- Intermediate (WE1, Google Trust Services) -->
            <pin digest="SHA-256">H7AMYAvicN2+UcFPBz3kJXCDmGrTItZh4ujUBK8hoWg=</pin>
        </pin-set>
    </domain-config>
</network-security-config>
